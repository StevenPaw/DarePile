{
    "name": "stevenpaw/darepile",
    "type": "silverstripe-recipe",
    "description": "A Silverstripe 6 project",
    "repositories": [
    ],
    "require": {
        "php": "^8.3",
        "silverstripe/recipe-core": "^6.1",
        "silverstripe/admin": "^3.1",
        "silverstripe/asset-admin": "^3.1",
        "atwx/silverstripe-vitehelper": "^1.4",
        "ext-json": "*",
        "symbiote/silverstripe-gridfieldextensions": "^5.1",
        "stevenpaw/silverstripe-cms-backend-theme": "^1.1",
        "stevenpaw/stevens-silverstripe-icons": "dev-main"
    },
    "require-dev": {
        "silverleague/ideannotator": "^4.0",
        "wernerkrauss/silverstripe-rector": "^1",
        "cambis/silverstan": "^2",
        "squizlabs/php_codesniffer": "^3",
        "phpstan/extension-installer": "^1.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/src/"
        }
    },
    "extra": {
        "expose": [
            "app/client/dist",
            "app/client/icons",
            "app/client/images"
        ],
        "resources-dir": "_resources",
        "project-files-installed": [
            "app/.htaccess",
            "app/_config.php",
            "app/_config/mimevalidator.yml",
            "app/_config/mysite.yml"
        ],
        "public-files-installed": [
            ".htaccess",
            "index.php",
            "web.config"
        ]
    },
    "prefer-stable": true,
    "minimum-stability": "dev",
    "scripts": {
        "lint": "vendor/bin/phpcs",
        "fix": "vendor/bin/phpcbf",
        "rector": "vendor/bin/rector -v",
        "rector-dry": "vendor/bin/rector -v --dry-run",
        "phpstan": "vendor/bin/phpstan"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/recipe-plugin": true,
            "silverstripe/vendor-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    }
}
